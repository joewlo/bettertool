# Postgres
DATABASE_URL=postgres://bettertool:bettertool@localhost:5432/bettertool

# Master key for encrypting resource secrets (AES-256-GCM). Generate with: openssl rand -base64 32
ENCRYPTION_KEY=dev-only-do-not-use-in-production-replace-me-32-bytes!!

# Auth (oauth2-proxy headers). All overridable.
AUTH_HEADER_EMAIL=X-Auth-Request-Email
AUTH_HEADER_USER=X-Auth-Request-User
AUTH_HEADER_GROUPS=X-Auth-Request-Groups
AUTH_HEADER_ACCESS_TOKEN=X-Auth-Request-Access-Token
# Comma-separated group names that grant admin
AUTH_ADMIN_GROUPS=admin

# API
API_PORT=8787
API_CORS_ORIGIN=http://localhost:5173

# Web
VITE_API_BASE_URL=http://localhost:8787
