{
  "name": "bettertool",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @bettertool/db db:generate",
    "db:push": "pnpm --filter @bettertool/db db:push",
    "db:studio": "pnpm --filter @bettertool/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
